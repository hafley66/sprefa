{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "sprf",
  "scopeName": "source.sprf",
  "patterns": [
    { "include": "#comment" },
    { "include": "#query-declaration" },
    { "include": "#link-declaration" },
    { "include": "#rule" }
  ],
  "repository": {
    "comment": {
      "match": "#.*$",
      "name": "comment.line.number-sign.sprf"
    },

    "link-declaration": {
      "begin": "\\b(link)\\s*\\(",
      "end": "\\);?",
      "beginCaptures": {
        "1": { "name": "keyword.control.link.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.terminator.sprf" }
      },
      "patterns": [
        { "include": "#comment" },
        {
          "match": "\\b(norm_eq|norm2_eq|string_eq|target_file_eq|same_repo|same_file|stem_eq_src|stem_eq_tgt|ext_eq_src|ext_eq_tgt|dir_eq_src|dir_eq_tgt)\\b",
          "name": "support.function.predicate.sprf"
        },
        {
          "match": ">",
          "name": "keyword.operator.arrow.sprf"
        },
        {
          "match": "\\$[A-Z_][A-Za-z0-9_]*",
          "name": "variable.other.capture.sprf"
        },
        {
          "match": "\\b[a-z_][a-z0-9_]*\\b",
          "name": "entity.name.type.kind.sprf"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.sprf"
        }
      ]
    },

    "query-declaration": {
      "begin": "\\b(query)\\s+([a-z_][a-z0-9_]*)\\s*\\(",
      "end": ";",
      "beginCaptures": {
        "1": { "name": "keyword.control.query.sprf" },
        "2": { "name": "entity.name.function.query.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.terminator.sprf" }
      },
      "patterns": [
        { "include": "#comment" },
        {
          "match": ":-",
          "name": "keyword.operator.horn.sprf"
        },
        {
          "match": "\\$[A-Z_][A-Za-z0-9_]*",
          "name": "variable.other.capture.sprf"
        },
        {
          "match": "\\$_",
          "name": "variable.language.wildcard.sprf"
        },
        {
          "match": "\\b[a-z_][a-z0-9_]*(?=\\s*\\()",
          "name": "entity.name.function.relation.sprf"
        },
        {
          "match": "\"[^\"]*\"",
          "name": "string.quoted.double.sprf"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.sprf"
        },
        {
          "match": "[()]",
          "name": "punctuation.bracket.round.sprf"
        }
      ]
    },

    "rule": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#query-declaration" },
        { "include": "#match-slot" },
        { "include": "#tagged-slot" },
        { "include": "#chain-separator" },
        { "include": "#semicolon" },
        { "include": "#capture" },
        { "include": "#bare-glob" }
      ]
    },

    "chain-separator": {
      "match": ">",
      "name": "keyword.operator.chain.sprf"
    },

    "semicolon": {
      "match": ";",
      "name": "punctuation.terminator.sprf"
    },

    "capture": {
      "match": "\\$_{1}(?![A-Za-z0-9])",
      "name": "variable.language.wildcard.sprf"
    },

    "match-slot": {
      "begin": "\\b(match)\\s*\\(",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "keyword.control.match.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        {
          "match": "\\$[A-Z_][A-Za-z0-9_]*",
          "name": "variable.other.capture.sprf"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.sprf"
        },
        {
          "match": "[a-z_][a-z0-9_]*",
          "name": "entity.name.type.kind.sprf"
        }
      ]
    },

    "tagged-slot": {
      "patterns": [
        { "include": "#json-slot" },
        { "include": "#ast-slot" },
        { "include": "#re-slot" },
        { "include": "#fs-slot" },
        { "include": "#repo-slot" },
        { "include": "#branch-slot" },
        { "include": "#rule-slot" }
      ]
    },

    "fs-slot": {
      "begin": "\\b(fs)\\s*\\(",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        {
          "match": "\\*\\*",
          "name": "keyword.operator.globstar.sprf"
        },
        {
          "match": "\\*",
          "name": "keyword.operator.glob.sprf"
        },
        {
          "match": "[^)]+",
          "name": "string.unquoted.glob.sprf"
        }
      ]
    },

    "repo-slot": {
      "begin": "\\b(repo)\\s*\\(",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        { "match": "[^)]+", "name": "string.unquoted.glob.sprf" }
      ]
    },

    "branch-slot": {
      "begin": "\\b(branch)\\s*\\(",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        { "match": "[^)]+", "name": "string.unquoted.glob.sprf" }
      ]
    },

    "rule-slot": {
      "begin": "\\b(rule)\\s*\\(",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        { "match": "[^)]+", "name": "entity.name.function.rule.sprf" }
      ]
    },

    "json-slot": {
      "begin": "\\b(json)\\s*\\(",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        { "include": "#json-body" }
      ]
    },

    "json-body": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#json-object" },
        { "include": "#json-array" },
        { "include": "#capture-screaming" },
        { "include": "#wildcard" },
        { "include": "#recursive-descent" },
        { "include": "#regex-key" },
        { "include": "#json-key" },
        { "include": "#json-punctuation" }
      ]
    },

    "json-object": {
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.bracket.curly.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.curly.sprf" }
      },
      "patterns": [
        { "include": "#json-body" }
      ]
    },

    "json-array": {
      "begin": "\\[",
      "end": "\\]",
      "beginCaptures": {
        "0": { "name": "punctuation.bracket.square.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.square.sprf" }
      },
      "patterns": [
        {
          "match": "\\.\\.\\.",
          "name": "keyword.operator.spread.sprf"
        },
        { "include": "#json-body" }
      ]
    },

    "recursive-descent": {
      "match": "\\*\\*",
      "name": "keyword.operator.recursive-descent.sprf"
    },

    "capture-screaming": {
      "match": "\\$[A-Z][A-Z0-9_]*",
      "name": "variable.other.capture.sprf"
    },

    "wildcard": {
      "match": "\\$_\\b",
      "name": "variable.language.wildcard.sprf"
    },

    "regex-key": {
      "match": "\\bre:.+?(?=:\\s)",
      "name": "string.regexp.key.sprf"
    },

    "json-key": {
      "match": "[a-zA-Z_*?][a-zA-Z0-9_*?.-]*(?=\\s*:)",
      "name": "entity.name.tag.key.sprf"
    },

    "json-punctuation": {
      "patterns": [
        { "match": ":", "name": "punctuation.separator.colon.sprf" },
        { "match": ",", "name": "punctuation.separator.comma.sprf" }
      ]
    },

    "ast-slot": {
      "begin": "\\b(ast)(?:\\[([a-z]+)\\])?\\s*\\(",
      "end": "\\)(?=\\s*[>;#]|\\s*$)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" },
        "2": { "name": "entity.name.type.language.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        {
          "match": "\\$\\$\\$[A-Z][A-Z0-9_]*",
          "name": "variable.other.capture.multi.sprf"
        },
        {
          "match": "\\$[A-Z][A-Z0-9_]*",
          "name": "variable.other.capture.sprf"
        },
        {
          "match": "[^)$]+",
          "name": "string.unquoted.pattern.sprf"
        }
      ]
    },

    "re-slot": {
      "match": "\\b(re)\\s*\\((.+)\\)(?=\\s*[>;#]|\\s*$)",
      "captures": {
        "1": { "name": "keyword.control.tag.sprf" },
        "2": { "name": "string.regexp.sprf" }
      }
    },

    "bare-glob": {
      "match": "[^>;#\\s][^>;#]*",
      "name": "string.unquoted.glob.sprf"
    }
  }
}
