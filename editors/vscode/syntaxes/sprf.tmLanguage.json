{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "sprf",
  "scopeName": "source.sprf",
  "patterns": [
    { "include": "#comment" },
    { "include": "#check-declaration" },
    { "include": "#rule-declaration" },
    { "include": "#rule" }
  ],
  "repository": {
    "comment": {
      "match": "#.*$",
      "name": "comment.line.number-sign.sprf"
    },

    "check-declaration": {
      "begin": "\\b(check)\\s*\\(\\s*([a-z_][a-z0-9_]*)\\s*\\)\\s*\\{",
      "end": "\\}\\s*;",
      "beginCaptures": {
        "1": { "name": "keyword.control.check.sprf" },
        "2": { "name": "entity.name.function.check.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.terminator.sprf" }
      },
      "patterns": [
        { "include": "#sql-body" }
      ]
    },

    "sql-body": {
      "patterns": [
        { "include": "#comment" },
        {
          "match": "\\b(SELECT|FROM|WHERE|JOIN|LEFT|RIGHT|INNER|OUTER|ON|AND|OR|NOT|IN|IS|NULL|AS|GROUP|BY|ORDER|HAVING|LIMIT|OFFSET|UNION|INSERT|INTO|VALUES|UPDATE|SET|DELETE|EXISTS|BETWEEN|LIKE|DISTINCT|COUNT|SUM|AVG|MIN|MAX|CASE|WHEN|THEN|ELSE|END|WITH|RECURSIVE)\\b",
          "name": "keyword.other.sql.sprf"
        },
        {
          "match": "'[^']*'",
          "name": "string.quoted.single.sql.sprf"
        },
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.sql.sprf"
        },
        {
          "match": "!=|<>|<=|>=|=|<|>",
          "name": "keyword.operator.comparison.sql.sprf"
        },
        {
          "match": "\\b[a-z_][a-z0-9_]*(?=\\s*\\.)",
          "name": "entity.name.type.table-alias.sql.sprf"
        }
      ]
    },

    "rule-declaration": {
      "begin": "\\b(rule)\\s*\\(\\s*([a-z_][a-z0-9_]*)\\s*\\)\\s*\\{",
      "end": "\\}\\s*;",
      "beginCaptures": {
        "1": { "name": "keyword.control.rule.sprf" },
        "2": { "name": "entity.name.function.rule.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.terminator.sprf" }
      },
      "patterns": [
        { "include": "#rule-body" }
      ]
    },

    "rule-body": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#tagged-slot" },
        { "include": "#cross-ref" },
        { "include": "#chain-separator" },
        { "include": "#semicolon" },
        { "include": "#capture-screaming" },
        { "include": "#wildcard" },
        { "include": "#bare-glob" }
      ]
    },

    "rule": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#rule-declaration" },
        { "include": "#check-declaration" },
        { "include": "#tagged-slot" },
        { "include": "#chain-separator" },
        { "include": "#semicolon" },
        { "include": "#capture-screaming" },
        { "include": "#wildcard" },
        { "include": "#bare-glob" }
      ]
    },

    "cross-ref": {
      "begin": "\\b([a-z_][a-z0-9_]*)\\s*\\((?=[^)]*:\\s*\\$)",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "entity.name.function.crossref.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        {
          "match": "\\b([a-z_][a-z0-9_]*)\\s*:",
          "captures": {
            "1": { "name": "variable.parameter.column.sprf" }
          }
        },
        { "include": "#capture-screaming" },
        {
          "match": ",",
          "name": "punctuation.separator.comma.sprf"
        }
      ]
    },

    "chain-separator": {
      "match": ">",
      "name": "keyword.operator.chain.sprf"
    },

    "semicolon": {
      "match": ";",
      "name": "punctuation.terminator.sprf"
    },

    "capture-screaming": {
      "match": "\\$\\$\\$[A-Z][A-Z0-9_]*",
      "name": "variable.other.capture.multi.sprf"
    },

    "capture-single": {
      "match": "\\$[A-Z][A-Z0-9_]*",
      "name": "variable.other.capture.sprf"
    },

    "wildcard": {
      "match": "\\$_(?![A-Za-z0-9])",
      "name": "variable.language.wildcard.sprf"
    },

    "tagged-slot": {
      "patterns": [
        { "include": "#json-slot" },
        { "include": "#ast-slot" },
        { "include": "#line-slot" },
        { "include": "#fs-slot" },
        { "include": "#repo-slot" },
        { "include": "#rev-slot" },
        { "include": "#folder-slot" },
        { "include": "#file-slot" },
        { "include": "#marker-slot" },
        { "include": "#md-slot" }
      ]
    },

    "fs-slot": {
      "begin": "\\b(fs)\\s*\\(",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        {
          "match": "\\*\\*",
          "name": "keyword.operator.globstar.sprf"
        },
        {
          "match": "\\*",
          "name": "keyword.operator.glob.sprf"
        },
        {
          "match": "\\|",
          "name": "keyword.operator.alternation.sprf"
        },
        {
          "match": "[^)|*]+",
          "name": "string.unquoted.glob.sprf"
        }
      ]
    },

    "repo-slot": {
      "begin": "\\b(repo)\\s*\\(",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        { "include": "#capture-screaming" },
        { "include": "#capture-single" },
        {
          "match": "\\*",
          "name": "keyword.operator.glob.sprf"
        },
        { "match": "[^)$*]+", "name": "string.unquoted.glob.sprf" }
      ]
    },

    "rev-slot": {
      "begin": "\\b(rev|branch|tag)\\s*\\(",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        { "include": "#capture-screaming" },
        { "include": "#capture-single" },
        {
          "match": "\\|",
          "name": "keyword.operator.alternation.sprf"
        },
        {
          "match": "\\*",
          "name": "keyword.operator.glob.sprf"
        },
        { "match": "[^)|$*]+", "name": "string.unquoted.glob.sprf" }
      ]
    },

    "folder-slot": {
      "begin": "\\b(folder)\\s*\\(",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        { "include": "#capture-screaming" },
        { "include": "#capture-single" },
        {
          "match": "\\*\\*",
          "name": "keyword.operator.globstar.sprf"
        },
        {
          "match": "\\*",
          "name": "keyword.operator.glob.sprf"
        },
        { "match": "[^)$*]+", "name": "string.unquoted.glob.sprf" }
      ]
    },

    "file-slot": {
      "begin": "\\b(file)\\s*\\(",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        { "include": "#capture-screaming" },
        { "include": "#capture-single" },
        {
          "match": "\\*\\*",
          "name": "keyword.operator.globstar.sprf"
        },
        {
          "match": "\\*",
          "name": "keyword.operator.glob.sprf"
        },
        { "match": "[^)$*]+", "name": "string.unquoted.glob.sprf" }
      ]
    },

    "marker-slot": {
      "begin": "\\b(marker)\\s*\\(",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        {
          "match": "\"([^\"]+)\"",
          "captures": {
            "0": { "name": "string.quoted.double.sprf" }
          }
        },
        { "match": ",", "name": "punctuation.separator.comma.sprf" }
      ]
    },

    "md-slot": {
      "begin": "\\b(md)\\s*\\(",
      "end": "\\)(?=\\s*[>;{}#]|\\s*$)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        {
          "match": "\\$\\$\\$[A-Z][A-Z0-9_]*",
          "name": "variable.other.capture.multi.sprf"
        },
        {
          "match": "\\$[A-Z][A-Z0-9_]*",
          "name": "variable.other.capture.sprf"
        },
        {
          "match": "\\$_(?![A-Za-z0-9])",
          "name": "variable.language.wildcard.sprf"
        },
        {
          "match": "[^)$]+",
          "name": "string.unquoted.pattern.sprf"
        }
      ]
    },

    "json-slot": {
      "begin": "\\b(json)\\s*\\(",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        { "include": "#json-body" }
      ]
    },

    "json-body": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#json-object" },
        { "include": "#json-array" },
        { "include": "#json-quoted-value" },
        { "include": "#capture-screaming" },
        { "include": "#capture-single" },
        { "include": "#wildcard" },
        { "include": "#recursive-descent" },
        { "include": "#regex-key" },
        { "include": "#json-key" },
        { "include": "#json-annotation" },
        { "include": "#json-punctuation" }
      ]
    },

    "json-object": {
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.bracket.curly.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.curly.sprf" }
      },
      "patterns": [
        { "include": "#json-body" }
      ]
    },

    "json-array": {
      "begin": "\\[",
      "end": "\\]",
      "beginCaptures": {
        "0": { "name": "punctuation.bracket.square.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.square.sprf" }
      },
      "patterns": [
        {
          "match": "\\.\\.\\.",
          "name": "keyword.operator.spread.sprf"
        },
        { "include": "#json-body" }
      ]
    },

    "json-quoted-value": {
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.sprf" }
      },
      "name": "string.quoted.double.sprf",
      "patterns": [
        { "include": "#capture-screaming" },
        { "include": "#capture-single" },
        { "include": "#wildcard" },
        {
          "match": "\\\\.",
          "name": "constant.character.escape.sprf"
        }
      ]
    },

    "json-annotation": {
      "match": "\\b(repo|rev)\\s*(?=\\()",
      "name": "storage.type.annotation.sprf"
    },

    "recursive-descent": {
      "match": "\\*\\*",
      "name": "keyword.operator.recursive-descent.sprf"
    },

    "regex-key": {
      "match": "\\bre:[^:,}\\]]+(?=\\s*:)",
      "name": "string.regexp.key.sprf"
    },

    "json-key": {
      "match": "[a-zA-Z_*?@][a-zA-Z0-9_*?./-]*(?=\\s*:)",
      "name": "entity.name.tag.key.sprf"
    },

    "json-punctuation": {
      "patterns": [
        { "match": ":", "name": "punctuation.separator.colon.sprf" },
        { "match": ",", "name": "punctuation.separator.comma.sprf" }
      ]
    },

    "ast-slot": {
      "begin": "\\b(ast)(?:\\[([a-z]+)\\])?\\s*\\(",
      "end": "\\)(?=\\s*[>;{}#]|\\s*$)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" },
        "2": { "name": "entity.name.type.language.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        {
          "match": "\\$\\$\\$[A-Z][A-Z0-9_]*",
          "name": "variable.other.capture.multi.sprf"
        },
        {
          "match": "\\$\\{[A-Z][A-Z0-9_]*\\}",
          "name": "variable.other.capture.braced.sprf"
        },
        {
          "match": "\\$[A-Z][A-Z0-9_]*",
          "name": "variable.other.capture.sprf"
        },
        {
          "match": "[^)$]+",
          "name": "string.unquoted.pattern.sprf"
        }
      ]
    },

    "line-slot": {
      "begin": "\\b(line)\\s*\\(",
      "end": "\\)(?=\\s*[>;{}#]|\\s*$)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tag.sprf" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.bracket.round.sprf" }
      },
      "patterns": [
        {
          "include": "#line-re-prefix"
        },
        {
          "match": "\\$\\$\\$[A-Z][A-Z0-9_]*",
          "name": "variable.other.capture.multi.sprf"
        },
        {
          "match": "\\$[A-Z][A-Z0-9_]*",
          "name": "variable.other.capture.sprf"
        },
        {
          "match": "\\$_(?![A-Za-z0-9])",
          "name": "variable.language.wildcard.sprf"
        },
        {
          "match": "[^)$]+",
          "name": "string.unquoted.pattern.sprf"
        }
      ]
    },

    "line-re-prefix": {
      "match": "\\bre:",
      "name": "keyword.operator.regex.sprf"
    },

    "bare-glob": {
      "match": "[^>;{}#\\s][^>;{}#]*",
      "name": "string.unquoted.glob.sprf"
    }
  }
}
