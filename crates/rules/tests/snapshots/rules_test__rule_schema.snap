---
source: crates/rules/tests/rules_test.rs
expression: schema
---
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RuleSet",
  "description": "Top-level rules file: an array of rules plus optional metadata.",
  "type": "object",
  "required": [
    "rules"
  ],
  "properties": {
    "$schema": {
      "type": [
        "string",
        "null"
      ]
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Rule"
      }
    }
  },
  "definitions": {
    "AstSelector": {
      "description": "ast-grep pattern selector for code files.",
      "type": "object",
      "required": [
        "pattern"
      ],
      "properties": {
        "capture": {
          "default": "$NAME",
          "type": "string"
        },
        "language": {
          "type": [
            "string",
            "null"
          ]
        },
        "pattern": {
          "type": "string"
        }
      }
    },
    "EmitRef": {
      "description": "One ref to emit from a match.",
      "type": "object",
      "required": [
        "capture",
        "kind"
      ],
      "properties": {
        "capture": {
          "description": "Name of the capture to use as the ref value.",
          "type": "string"
        },
        "kind": {
          "description": "Free-text kind string (e.g. \"dep_name\", \"helm_value\", \"operation_id\").",
          "type": "string"
        },
        "parent": {
          "description": "Name of another capture to use as parent_key (links related refs).",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "FileSelector": {
      "description": "File path selector. Single glob or list of globs.",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "GitSelector": {
      "description": "Git context selector. All fields are glob patterns (pipe-delimited alternatives).",
      "type": "object",
      "properties": {
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "repo": {
          "type": [
            "string",
            "null"
          ]
        },
        "tag": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Rule": {
      "description": "A single extraction rule.\n\nSelector chain: git context -> file path -> structural position. Think of the entire indexed space as a DOM: root > repo[name][branch] > file[path][ext] > (parsed tree nodes) Each rule is a CSS selector against this DOM. All nodes matching the full chain produce captures, and the action turns captures into refs.",
      "type": "object",
      "required": [
        "emit",
        "file",
        "name"
      ],
      "properties": {
        "confidence": {
          "description": "Confidence score override (0.0 to 1.0). Default: 0.8 for rule matches.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "emit": {
          "description": "Each entry turns a named capture into a ref.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/EmitRef"
          }
        },
        "file": {
          "$ref": "#/definitions/FileSelector"
        },
        "git": {
          "anyOf": [
            {
              "$ref": "#/definitions/GitSelector"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "select": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/StructStep"
          }
        },
        "select_ast": {
          "anyOf": [
            {
              "$ref": "#/definitions/AstSelector"
            },
            {
              "type": "null"
            }
          ]
        },
        "value": {
          "description": "Regex applied to a named capture to split/filter it. Named groups from the regex merge back into the capture map.",
          "anyOf": [
            {
              "$ref": "#/definitions/ValuePattern"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "StructStep": {
      "description": "One step in a structural selector chain.\n\nSteps are consumed left-to-right as the engine walks the parsed tree depth-first. Each step either narrows the current node set or captures a value for later use by the action.\n\nThe `capture` field on Key/KeyMatch/Leaf/Object steps names the value so the action's `emit` array can reference it.",
      "oneOf": [
        {
          "description": "Enter the child with this exact key name.",
          "type": "object",
          "required": [
            "name",
            "step"
          ],
          "properties": {
            "capture": {
              "type": [
                "string",
                "null"
              ]
            },
            "name": {
              "type": "string"
            },
            "step": {
              "type": "string",
              "enum": [
                "key"
              ]
            }
          }
        },
        {
          "description": "Enter children whose key matches this glob pattern (pipe-delimited).",
          "type": "object",
          "required": [
            "pattern",
            "step"
          ],
          "properties": {
            "capture": {
              "type": [
                "string",
                "null"
              ]
            },
            "pattern": {
              "type": "string"
            },
            "step": {
              "type": "string",
              "enum": [
                "key_match"
              ]
            }
          }
        },
        {
          "description": "Descend through any number of levels (like CSS `**` or jq `..`).",
          "type": "object",
          "required": [
            "step"
          ],
          "properties": {
            "step": {
              "type": "string",
              "enum": [
                "any"
              ]
            }
          }
        },
        {
          "description": "Filter: current depth >= n (0 = root).",
          "type": "object",
          "required": [
            "n",
            "step"
          ],
          "properties": {
            "n": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            },
            "step": {
              "type": "string",
              "enum": [
                "depth_min"
              ]
            }
          }
        },
        {
          "description": "Filter: current depth <= n.",
          "type": "object",
          "required": [
            "n",
            "step"
          ],
          "properties": {
            "n": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            },
            "step": {
              "type": "string",
              "enum": [
                "depth_max"
              ]
            }
          }
        },
        {
          "description": "Filter: current depth == n.",
          "type": "object",
          "required": [
            "n",
            "step"
          ],
          "properties": {
            "n": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            },
            "step": {
              "type": "string",
              "enum": [
                "depth_eq"
              ]
            }
          }
        },
        {
          "description": "Filter: parent key matches this glob pattern.",
          "type": "object",
          "required": [
            "pattern",
            "step"
          ],
          "properties": {
            "pattern": {
              "type": "string"
            },
            "step": {
              "type": "string",
              "enum": [
                "parent_key"
              ]
            }
          }
        },
        {
          "description": "Descend into array elements.",
          "type": "object",
          "required": [
            "step"
          ],
          "properties": {
            "step": {
              "type": "string",
              "enum": [
                "array_item"
              ]
            }
          }
        },
        {
          "description": "Filter: node is a leaf (string, number, bool). Captures the leaf value.",
          "type": "object",
          "required": [
            "step"
          ],
          "properties": {
            "capture": {
              "type": [
                "string",
                "null"
              ]
            },
            "step": {
              "type": "string",
              "enum": [
                "leaf"
              ]
            }
          }
        },
        {
          "description": "Capture multiple sibling keys from an object node at once. Map of json_key -> capture_name. Example: `{ \"repository\": \"repo\", \"tag\": \"tag\" }`",
          "type": "object",
          "required": [
            "captures",
            "step"
          ],
          "properties": {
            "captures": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "step": {
              "type": "string",
              "enum": [
                "object"
              ]
            }
          }
        }
      ]
    },
    "ValuePattern": {
      "description": "Regex applied to a named capture. Named groups from the regex merge into the capture map, enabling split/transform of captured values.",
      "type": "object",
      "required": [
        "pattern",
        "source"
      ],
      "properties": {
        "full_match": {
          "description": "Anchor the regex to the full string. Default: true.",
          "default": true,
          "type": "boolean"
        },
        "pattern": {
          "description": "Regex pattern with named groups via `(?P<name>...)`.",
          "type": "string"
        },
        "source": {
          "description": "Which capture to run the regex against.",
          "type": "string"
        }
      }
    }
  }
}
