---
source: crates/rules/tests/rules_test.rs
expression: schema
---
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RuleSet",
  "description": "Top-level rules file: an array of rules plus optional metadata.",
  "type": "object",
  "required": [
    "rules"
  ],
  "properties": {
    "$schema": {
      "type": [
        "string",
        "null"
      ]
    },
    "link_rules": {
      "description": "Link rules create edges in `match_links` between matches produced by extraction rules. Each link rule uses either a `predicate` (structured DSL compiled to SQL) or a raw `sql` WHERE clause injected into a fixed query skeleton. Exactly one must be set.\n\n## Predicate DSL (preferred)\n\n```json { \"kind\": \"import_binding\", \"predicate\": { \"op\": \"and\", \"all\": [ { \"op\": \"kind_eq\", \"side\": \"src\", \"value\": \"import_name\" }, { \"op\": \"kind_eq\", \"side\": \"tgt\", \"value\": \"export_name\" }, { \"op\": \"target_file_eq\" }, { \"op\": \"string_eq\" } ] } } ```\n\nAvailable predicates: `kind_eq`, `norm_eq`, `norm2_eq`, `target_file_eq`, `string_eq`, `same_repo`, `and`.\n\n## Raw SQL escape hatch\n\nFor predicates the DSL cannot express, use `sql` with a raw WHERE fragment. The fragment is interpolated directly (no sanitization). Available aliases: src_m, src_r, src_s, src_f, src_rp, tgt_m, tgt_r, tgt_s, tgt_f.\n\n```json { \"kind\": \"dependency\", \"sql\": \"src_m.kind = 'dep_name' AND tgt_m.kind = 'package_name' AND src_s.norm = tgt_s.norm\" } ```",
      "type": "array",
      "items": {
        "$ref": "#/definitions/LinkRule"
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Rule"
      }
    }
  },
  "definitions": {
    "AstSelector": {
      "description": "ast-grep pattern selector for code files.",
      "type": "object",
      "required": [
        "pattern"
      ],
      "properties": {
        "capture": {
          "description": "Single-capture: the whole matched node's text goes into this capture name. Ignored when `captures` is set. Default: \"$NAME\".",
          "default": "$NAME",
          "type": "string"
        },
        "captures": {
          "description": "Multi-capture: map of metavar (e.g. \"$FUNC\") to capture name (e.g. \"name\"). When set, each listed metavar is extracted as a separate capture.",
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "string"
          }
        },
        "language": {
          "type": [
            "string",
            "null"
          ]
        },
        "pattern": {
          "type": "string"
        }
      }
    },
    "LinkPredicate": {
      "description": "Structured predicate for link rules, compiled to SQL WHERE fragments.\n\nEach variant maps to a specific SQL condition against the link skeleton's aliases (src_m, src_r, src_s, src_f, tgt_m, tgt_r, tgt_s, tgt_f).",
      "oneOf": [
        {
          "description": "Match kind on one side: `{side}_m.kind = '{value}'`",
          "type": "object",
          "required": [
            "op",
            "side",
            "value"
          ],
          "properties": {
            "op": {
              "type": "string",
              "enum": [
                "kind_eq"
              ]
            },
            "side": {
              "$ref": "#/definitions/Side"
            },
            "value": {
              "type": "string"
            }
          }
        },
        {
          "description": "Normalized strings equal: `src_s.norm = tgt_s.norm`",
          "type": "object",
          "required": [
            "op"
          ],
          "properties": {
            "op": {
              "type": "string",
              "enum": [
                "norm_eq"
              ]
            }
          }
        },
        {
          "description": "Secondary normalization equal: `src_s.norm2 = tgt_s.norm2`",
          "type": "object",
          "required": [
            "op"
          ],
          "properties": {
            "op": {
              "type": "string",
              "enum": [
                "norm2_eq"
              ]
            }
          }
        },
        {
          "description": "Source's resolved target file matches target's file: `src_r.target_file_id = tgt_r.file_id`",
          "type": "object",
          "required": [
            "op"
          ],
          "properties": {
            "op": {
              "type": "string",
              "enum": [
                "target_file_eq"
              ]
            }
          }
        },
        {
          "description": "Same string_id on both sides: `tgt_r.string_id = src_r.string_id`",
          "type": "object",
          "required": [
            "op"
          ],
          "properties": {
            "op": {
              "type": "string",
              "enum": [
                "string_eq"
              ]
            }
          }
        },
        {
          "description": "Both matches in the same repo: `src_f.repo_id = tgt_f.repo_id`",
          "type": "object",
          "required": [
            "op"
          ],
          "properties": {
            "op": {
              "type": "string",
              "enum": [
                "same_repo"
              ]
            }
          }
        },
        {
          "description": "All sub-predicates must hold.",
          "type": "object",
          "required": [
            "all",
            "op"
          ],
          "properties": {
            "all": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/LinkPredicate"
              }
            },
            "op": {
              "type": "string",
              "enum": [
                "and"
              ]
            }
          }
        }
      ]
    },
    "LinkRule": {
      "description": "A link rule creates edges in `match_links` between matches.\n\nExactly one of `sql` or `predicate` must be set. The predicate DSL covers common patterns (kind checks, norm equality, file scoping). The raw `sql` escape hatch remains for anything the DSL can't express.",
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "description": "Identifier for this link rule. Written to match_links.link_kind and used in log messages.",
          "type": "string"
        },
        "predicate": {
          "description": "Structured predicate compiled to SQL at runtime.",
          "anyOf": [
            {
              "$ref": "#/definitions/LinkPredicate"
            },
            {
              "type": "null"
            }
          ]
        },
        "sql": {
          "description": "Raw SQL WHERE clause. Plugged into the skeleton as `AND (<sql>)`. Available aliases: src_m, src_r, src_s, src_f, src_rp, tgt_m, tgt_r, tgt_s, tgt_f.",
          "type": [
            "string",
            "null"
          ]
        },
        "target_repos": {
          "description": "Restrict target matches to these repo names. When set, only matches in the listed repos can be link targets. When absent, targets are unconstrained (cross-repo by default).",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "MatchDef": {
      "description": "One match to create from a captured value.",
      "type": "object",
      "required": [
        "capture",
        "kind"
      ],
      "properties": {
        "capture": {
          "description": "Name of the capture to use as the ref value.",
          "type": "string"
        },
        "kind": {
          "description": "Free-text kind string (e.g. \"dep_name\", \"helm_value\", \"operation_id\").",
          "type": "string"
        },
        "parent": {
          "description": "Name of another capture to use as parent_key (links related refs).",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Rule": {
      "description": "A single extraction rule.\n\nThe `select` chain is a CSS selector against the full index DOM: root > repo > branch > tag > folder* > file > (parsed tree nodes)\n\nContext steps (Repo, Branch, Tag, Folder, File) filter by git context and file path before the file is parsed. Structural steps (Key, KeyMatch, Any, etc.) walk the parsed tree to produce captures.\n\nOrdering constraint enforced at compile time: all context steps must precede all structural steps.",
      "type": "object",
      "required": [
        "create_matches",
        "name",
        "select"
      ],
      "properties": {
        "confidence": {
          "description": "Confidence score override (0.0 to 1.0). Default: 0.8 for rule matches.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "create_matches": {
          "description": "Each entry turns a named capture into a match row.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/MatchDef"
          }
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "select": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/SelectStep"
          }
        },
        "select_ast": {
          "anyOf": [
            {
              "$ref": "#/definitions/AstSelector"
            },
            {
              "type": "null"
            }
          ]
        },
        "value": {
          "description": "Regex applied to a named capture to split/filter it. Named groups from the regex merge back into the capture map.",
          "anyOf": [
            {
              "$ref": "#/definitions/ValuePattern"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "SelectStep": {
      "description": "One step in a selector chain.\n\nContext steps filter before parsing. Structural steps walk the parsed tree. Pattern fields use pipe-delimited glob syntax: `\"main|release/*\"`.\n\nFor Folder: `*` captures one path segment, `**` captures the remaining path. For File: glob matches against the full relative file path.",
      "oneOf": [
        {
          "description": "Filter by repository name (pipe-delimited glob).",
          "type": "object",
          "required": [
            "pattern",
            "step"
          ],
          "properties": {
            "capture": {
              "type": [
                "string",
                "null"
              ]
            },
            "pattern": {
              "type": "string"
            },
            "step": {
              "type": "string",
              "enum": [
                "repo"
              ]
            }
          }
        },
        {
          "description": "Filter by branch name (pipe-delimited glob).",
          "type": "object",
          "required": [
            "pattern",
            "step"
          ],
          "properties": {
            "capture": {
              "type": [
                "string",
                "null"
              ]
            },
            "pattern": {
              "type": "string"
            },
            "step": {
              "type": "string",
              "enum": [
                "branch"
              ]
            }
          }
        },
        {
          "description": "Filter by git tag (pipe-delimited glob).",
          "type": "object",
          "required": [
            "pattern",
            "step"
          ],
          "properties": {
            "capture": {
              "type": [
                "string",
                "null"
              ]
            },
            "pattern": {
              "type": "string"
            },
            "step": {
              "type": "string",
              "enum": [
                "tag"
              ]
            }
          }
        },
        {
          "description": "Filter by directory path (pipe-delimited glob against dir portion).",
          "type": "object",
          "required": [
            "pattern",
            "step"
          ],
          "properties": {
            "capture": {
              "type": [
                "string",
                "null"
              ]
            },
            "pattern": {
              "type": "string"
            },
            "step": {
              "type": "string",
              "enum": [
                "folder"
              ]
            }
          }
        },
        {
          "description": "Filter by file path (pipe-delimited glob against full relative path).",
          "type": "object",
          "required": [
            "pattern",
            "step"
          ],
          "properties": {
            "capture": {
              "type": [
                "string",
                "null"
              ]
            },
            "pattern": {
              "type": "string"
            },
            "step": {
              "type": "string",
              "enum": [
                "file"
              ]
            }
          }
        },
        {
          "description": "Enter the child with this exact key name.",
          "type": "object",
          "required": [
            "name",
            "step"
          ],
          "properties": {
            "capture": {
              "type": [
                "string",
                "null"
              ]
            },
            "name": {
              "type": "string"
            },
            "step": {
              "type": "string",
              "enum": [
                "key"
              ]
            }
          }
        },
        {
          "description": "Enter children whose key matches this glob pattern (pipe-delimited).",
          "type": "object",
          "required": [
            "pattern",
            "step"
          ],
          "properties": {
            "capture": {
              "type": [
                "string",
                "null"
              ]
            },
            "pattern": {
              "type": "string"
            },
            "step": {
              "type": "string",
              "enum": [
                "key_match"
              ]
            }
          }
        },
        {
          "description": "Descend through any number of levels (like CSS `**` or jq `..`).",
          "type": "object",
          "required": [
            "step"
          ],
          "properties": {
            "step": {
              "type": "string",
              "enum": [
                "any"
              ]
            }
          }
        },
        {
          "description": "Filter: current depth >= n (0 = root).",
          "type": "object",
          "required": [
            "n",
            "step"
          ],
          "properties": {
            "n": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            },
            "step": {
              "type": "string",
              "enum": [
                "depth_min"
              ]
            }
          }
        },
        {
          "description": "Filter: current depth <= n.",
          "type": "object",
          "required": [
            "n",
            "step"
          ],
          "properties": {
            "n": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            },
            "step": {
              "type": "string",
              "enum": [
                "depth_max"
              ]
            }
          }
        },
        {
          "description": "Filter: current depth == n.",
          "type": "object",
          "required": [
            "n",
            "step"
          ],
          "properties": {
            "n": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            },
            "step": {
              "type": "string",
              "enum": [
                "depth_eq"
              ]
            }
          }
        },
        {
          "description": "Filter: parent key matches this glob pattern.",
          "type": "object",
          "required": [
            "pattern",
            "step"
          ],
          "properties": {
            "pattern": {
              "type": "string"
            },
            "step": {
              "type": "string",
              "enum": [
                "parent_key"
              ]
            }
          }
        },
        {
          "description": "Descend into array elements.",
          "type": "object",
          "required": [
            "step"
          ],
          "properties": {
            "step": {
              "type": "string",
              "enum": [
                "array_item"
              ]
            }
          }
        },
        {
          "description": "Filter: node is a leaf (string, number, bool). Captures the leaf value.",
          "type": "object",
          "required": [
            "step"
          ],
          "properties": {
            "capture": {
              "type": [
                "string",
                "null"
              ]
            },
            "step": {
              "type": "string",
              "enum": [
                "leaf"
              ]
            }
          }
        },
        {
          "description": "Capture multiple sibling keys from an object node at once. Map of json_key -> capture_name. Example: `{ \"repository\": \"repo\", \"tag\": \"tag\" }`",
          "type": "object",
          "required": [
            "captures",
            "step"
          ],
          "properties": {
            "captures": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "step": {
              "type": "string",
              "enum": [
                "object"
              ]
            }
          }
        }
      ]
    },
    "Side": {
      "description": "Which side of a link (source or target) a predicate applies to.",
      "type": "string",
      "enum": [
        "src",
        "tgt"
      ]
    },
    "ValuePattern": {
      "description": "Regex applied to a named capture. Named groups from the regex merge into the capture map, enabling split/transform of captured values.",
      "type": "object",
      "required": [
        "pattern",
        "source"
      ],
      "properties": {
        "full_match": {
          "description": "Anchor the regex to the full string. Default: true.",
          "default": true,
          "type": "boolean"
        },
        "pattern": {
          "description": "Regex pattern with named groups via `(?P<name>...)`.",
          "type": "string"
        },
        "source": {
          "description": "Which capture to run the regex against.",
          "type": "string"
        }
      }
    }
  }
}
