---
source: crates/rules/tests/rules_test.rs
expression: ruleset
---
$schema: sprefa-rules.schema.json
rules:
  - name: helm-image-refs
    description: Docker image references in Helm values files
    select:
      - step: repo
        pattern: "*/helm-charts"
      - step: branch
        pattern: main|release/*
      - step: tag
        pattern: v*
      - step: file
        pattern: values.yaml|values-*.yaml
      - step: any
      - step: key
        name: image
      - step: object
        captures:
          repository: repo
          tag: tag
    emit:
      - capture: repo
        kind: dep_name
      - capture: tag
        kind: dep_version
        parent: repo
    confidence: 0.9
