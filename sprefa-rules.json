{
  "$schema": "./sprefa-rules.schema.json",
  "rules": [
    {
      "name": "cargo-package-name",
      "description": "Package name declared in Cargo.toml [package] section",
      "select": [
        { "step": "file", "pattern": "**/Cargo.toml" },
        { "step": "key", "name": "package" },
        { "step": "key", "name": "name" },
        { "step": "leaf", "capture": "name" }
      ],
      "create_matches": [
        { "capture": "name", "kind": "package_name" }
      ]
    },
    {
      "name": "cargo-deps",
      "description": "Dependency names from Cargo.toml files",
      "select": [
        { "step": "file", "pattern": "**/Cargo.toml" },
        { "step": "key_match", "pattern": "dependencies|dev-dependencies|build-dependencies", "capture": "dep_type" },
        { "step": "key_match", "pattern": "*", "capture": "name" }
      ],
      "create_matches": [
        { "capture": "name", "kind": "dep_name" }
      ]
    },
    {
      "name": "package-json-name",
      "description": "Package name declared in package.json",
      "select": [
        { "step": "file", "pattern": "**/package.json" },
        { "step": "key", "name": "name" },
        { "step": "leaf", "capture": "name" }
      ],
      "create_matches": [
        { "capture": "name", "kind": "package_name" }
      ]
    },
    {
      "name": "package-json-deps",
      "description": "Dependency names and versions from package.json files",
      "select": [
        { "step": "file", "pattern": "**/package.json" },
        { "step": "key_match", "pattern": "dependencies|devDependencies|peerDependencies", "capture": "dep_type" },
        { "step": "key_match", "pattern": "*", "capture": "name" },
        { "step": "leaf", "capture": "version" }
      ],
      "create_matches": [
        { "capture": "name", "kind": "dep_name" },
        { "capture": "version", "kind": "dep_version", "parent": "name" }
      ]
    },
    {
      "name": "tsconfig-paths",
      "description": "Path alias mappings from tsconfig.json compilerOptions.paths",
      "select": [
        { "step": "file", "pattern": "**/tsconfig.json" },
        { "step": "key", "name": "compilerOptions" },
        { "step": "key", "name": "paths" },
        { "step": "key_match", "pattern": "*", "capture": "alias" },
        { "step": "array_item" },
        { "step": "leaf", "capture": "target" }
      ],
      "create_matches": [
        { "capture": "alias", "kind": "path_alias" },
        { "capture": "target", "kind": "import_path", "parent": "alias" }
      ]
    },
    {
      "name": "package-json-exports",
      "description": "Package entry points from package.json exports fields",
      "select": [
        { "step": "file", "pattern": "**/package.json" },
        { "step": "key", "name": "exports" },
        { "step": "key_match", "pattern": "*", "capture": "subpath" },
        { "step": "any" },
        { "step": "leaf", "capture": "entry" }
      ],
      "create_matches": [
        { "capture": "subpath", "kind": "package_entry" },
        { "capture": "entry", "kind": "import_path", "parent": "subpath" }
      ]
    },
    {
      "name": "deploy-values",
      "description": "Configuration values from deploy values.yaml files",
      "select": [
        { "step": "file", "pattern": "**/values.yaml|**/values-*.yaml" },
        { "step": "any" },
        { "step": "depth_min", "n": 1 },
        { "step": "leaf", "capture": "val" }
      ],
      "create_matches": [
        { "capture": "val", "kind": "deploy_value" }
      ]
    },
    {
      "name": "k8s-configmap-envs",
      "description": "Environment variable names from Kubernetes ConfigMap data keys",
      "select": [
        { "step": "file", "pattern": "**/*configmap*.yaml" },
        { "step": "key", "name": "data" },
        { "step": "key_match", "pattern": "*", "capture": "key" }
      ],
      "create_matches": [
        { "capture": "key", "kind": "env_var_name" }
      ]
    },
    {
      "name": "docker-compose-services",
      "description": "Service names from docker-compose files",
      "select": [
        { "step": "file", "pattern": "**/docker-compose.yaml|**/docker-compose.yml|**/docker-compose*.yaml|**/docker-compose*.yml" },
        { "step": "key", "name": "services" },
        { "step": "key_match", "pattern": "*", "capture": "name" }
      ],
      "create_matches": [
        { "capture": "name", "kind": "service_name" }
      ]
    },
    {
      "name": "openapi-operations",
      "description": "Operation IDs from OpenAPI spec files",
      "select": [
        { "step": "file", "pattern": "**/openapi.yaml|**/openapi.yml|**/openapi*.yaml|**/openapi*.yml|**/openapi.json" },
        { "step": "key", "name": "paths" },
        { "step": "key_match", "pattern": "*", "capture": "path" },
        { "step": "key_match", "pattern": "get|post|put|delete|patch|options|head", "capture": "method" },
        { "step": "key", "name": "operationId" },
        { "step": "leaf", "capture": "op_id" }
      ],
      "create_matches": [
        { "capture": "op_id", "kind": "operation_id" }
      ]
    },
    {
      "name": "cargo-workspace-members",
      "description": "Workspace member paths from Cargo.toml",
      "select": [
        { "step": "file", "pattern": "**/Cargo.toml" },
        { "step": "key", "name": "workspace" },
        { "step": "key", "name": "members" },
        { "step": "array_item" },
        { "step": "leaf", "capture": "member" }
      ],
      "create_matches": [
        { "capture": "member", "kind": "workspace_member" }
      ]
    },
    {
      "name": "pnpm-workspace",
      "description": "Workspace package globs from pnpm-workspace.yaml",
      "select": [
        { "step": "file", "pattern": "**/pnpm-workspace.yaml" },
        { "step": "key", "name": "packages" },
        { "step": "array_item" },
        { "step": "leaf", "capture": "member" }
      ],
      "create_matches": [
        { "capture": "member", "kind": "workspace_member" }
      ]
    },
    {
      "name": "js-env-var-refs",
      "description": "Environment variable references via process.env in JS/TS source",
      "select": [
        { "step": "file", "pattern": "**/*.js|**/*.jsx|**/*.cjs|**/*.mjs|**/*.ts|**/*.tsx|**/*.cts|**/*.mts" }
      ],
      "select_ast": {
        "pattern": "process.env.$NAME",
        "captures": { "$NAME": "env_ref" }
      },
      "create_matches": [
        { "capture": "env_ref", "kind": "env_var_ref" }
      ]
    },
    {
      "name": "deploy-image",
      "description": "Container image references from deploy values files",
      "select": [
        { "step": "file", "pattern": "**/values.yaml|**/values-*.yaml" },
        { "step": "any" },
        { "step": "key", "name": "image" },
        { "step": "object", "entries": [
          { "key": "repository", "value": [{ "step": "leaf", "capture": "repo" }] },
          { "key": "tag", "value": [{ "step": "leaf", "capture": "tag" }] }
        ] }
      ],
      "create_matches": [
        { "capture": "repo", "kind": "image_repo" },
        { "capture": "tag", "kind": "image_tag", "parent": "repo" }
      ]
    }
  ],
  "link_rules": [
    {
      "kind": "import_binding",
      "predicate": {
        "op": "and",
        "all": [
          { "op": "kind_eq", "side": "src", "value": "import_name" },
          { "op": "kind_eq", "side": "tgt", "value": "export_name" },
          { "op": "target_file_eq" },
          { "op": "string_eq" }
        ]
      }
    },
    {
      "kind": "image_source",
      "predicate": {
        "op": "and",
        "all": [
          { "op": "kind_eq", "side": "src", "value": "image_repo" },
          { "op": "kind_eq", "side": "tgt", "value": "package_name" },
          { "op": "norm_eq" }
        ]
      }
    },
    {
      "kind": "dep_to_package",
      "predicate": {
        "op": "and",
        "all": [
          { "op": "kind_eq", "side": "src", "value": "dep_name" },
          { "op": "kind_eq", "side": "tgt", "value": "package_name" },
          { "op": "norm_eq" }
        ]
      }
    },
    {
      "kind": "env_var_binding",
      "predicate": {
        "op": "and",
        "all": [
          { "op": "kind_eq", "side": "src", "value": "env_var_ref" },
          { "op": "kind_eq", "side": "tgt", "value": "env_var_name" },
          { "op": "norm_eq" }
        ]
      }
    }
  ]
}
